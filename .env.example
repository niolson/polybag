APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production: Set SESSION_SECURE_COOKIE=true (requires HTTPS)
# Production: Set SESSION_ENCRYPT=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Shipment Import (external database)
SHIPMENT_IMPORT_DB_DRIVER=mysql
SHIPMENT_IMPORT_DB_HOST=127.0.0.1
SHIPMENT_IMPORT_DB_PORT=3306
SHIPMENT_IMPORT_DB_DATABASE=
SHIPMENT_IMPORT_DB_USERNAME=root
SHIPMENT_IMPORT_DB_PASSWORD=
SHIPMENT_IMPORT_SHIPMENTS_QUERY=
SHIPMENT_IMPORT_ITEMS_QUERY=

# USPS API
USPS_API_BASE_URL=https://apis.usps.com
USPS_API_SANDBOX_URL=https://apis-tem.usps.com
USPS_API_CLIENT_ID=
USPS_API_CLIENT_SECRET=
USPS_CRID=
USPS_MID=

# FedEx API
FEDEX_API_BASE_URL=https://apis.fedex.com
FEDEX_API_SANDBOX_URL=https://apis-sandbox.fedex.com
FEDEX_API_KEY=
FEDEX_API_SECRET=
FEDEX_ACCOUNT_NUMBER=

# Shopify API
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_API_VERSION=2025-01
SHOPIFY_CHANNEL_NAME=Shopify
SHOPIFY_NOTIFY_CUSTOMER=false
SHIPMENT_IMPORT_SHOPIFY_ENABLED=false
SHIPMENT_EXPORT_SHOPIFY_ENABLED=false

# Shipping Configuration
SHIPPING_ORIGIN_ZIP=
SHIPPING_FROM_FIRST_NAME=Shipping
SHIPPING_FROM_LAST_NAME=Center
SHIPPING_FROM_COMPANY=
SHIPPING_FROM_STREET=
SHIPPING_FROM_CITY=
SHIPPING_FROM_STATE=
SHIPPING_FROM_ZIP_PLUS4=
SHIPPING_FROM_PHONE=

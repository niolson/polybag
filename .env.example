APP_NAME=PolyBag
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Deployment Modes:
# -----------------------------------------------------------------
# Standalone (on-prem): DB_HOST=mysql, REDIS_HOST=redis
#   Start with: docker compose --profile standalone up -d
#
# Shared (multi-tenant): DB_HOST=shared-mysql, REDIS_HOST=shared-redis
#   Requires shared infra running (see infra/docker-compose.yml)
#   Start with: docker compose up -d
#
# External (managed): DB_HOST=rds.example.com, REDIS_HOST=cache.example.com
#   Point to your managed database/cache services
#   Start with: docker compose up -d
# -----------------------------------------------------------------

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=cache
APP_MAINTENANCE_STORE=redis

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_ENCRYPT=false
# Production: Set SESSION_SECURE_COOKIE=true (requires HTTPS)
# Production: Set SESSION_ENCRYPT=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX= (must be unique per instance if sharing Redis)

# Redis key prefix — required when sharing Redis across tenants
# REDIS_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# On-prem: port for nginx when not using Caddy reverse proxy
# APP_PORT=80

# QZ Tray certificate paths (override for shared/custom locations)
# QZ_PRIVATE_KEY_PATH=./storage/app/private/qz-private-key.pem
# QZ_CERTIFICATE_PATH=./public/qz-certificate.pem

# Carrier, Shopify, Amazon, and import-source credentials are configured in the app settings UI.

# Google SSO (optional — enable via Settings page)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth Broker (connect.polybag.app)
# Handles OAuth authorization code flow for all instances
OAUTH_BROKER_URL=
OAUTH_BROKER_SECRET=
OAUTH_INSTANCE_ID=

# Shipment Import Settings
# E2E Testing (registers fake carrier adapters and address validator)
FAKE_CARRIERS=false

SHIPMENT_IMPORT_DATABASE_ENABLED=true
SHIPMENT_IMPORT_BATCH_SIZE=100
SHIPMENT_IMPORT_AUTO_UPDATE_PRODUCTS=true
SHIPMENT_IMPORT_LOG_CHANNEL=shipment-import
SHIPMENT_IMPORT_MARK_EXPORTED=false
SHIPMENT_EXPORT_DATABASE_ENABLED=false

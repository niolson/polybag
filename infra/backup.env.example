# S3-compatible storage credentials for database backups
# Copy to /opt/shared/backup.env on the server and fill in values

S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=polybag
S3_ENDPOINT=https://hel1.your-objectstorage.com
S3_PREFIX=backups/db
BACKUP_RETENTION_DAYS=30

# Override if using standalone MySQL instead of shared
# MYSQL_CONTAINER=mysql
